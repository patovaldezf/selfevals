# Local development environment for selfevals.
# Copy to `.env` and adjust. The real `.env` is gitignored; this template is not.
#
# Storage is Postgres-only. Bring up the local Postgres + Redis with:
#   docker compose up -d postgres redis
# which maps Postgres to :5433 and Redis to :6380 (see docker-compose.yml).

# Primary storage backend (REQUIRED — there is no SQLite fallback).
SELFEVALS_STORAGE_URL="postgresql://selfevals:selfevals@localhost:5433/selfevals"

# Postgres used by the test suite. pytest-postgresql clones a fresh database
# per test from this server (it never touches the database named in the URL).
SELFEVALS_TEST_POSTGRES_URL="postgresql://selfevals:selfevals@localhost:5433/selfevals"

# Live events + run-job queue (optional; the API/worker use Redis Streams).
SELFEVALS_REDIS_URL="redis://localhost:6380/15"

# Filesystem object store for large trace payloads (optional; default ./objects).
# SELFEVALS_OBJECTS_DIR="./objects"

# Provider API keys (only needed for live runs against a real model).
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
